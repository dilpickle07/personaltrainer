/**
 * backend/.env.example
 * 
 * Copy this to .env and configure for your environment.
 * Supports multiple database backends!
 */

# ============================================================================
# DATABASE SELECTION
# ============================================================================
# Choose your database backend: postgresql, mongodb, or both
DATABASE_TYPE=postgresql
# DATABASE_TYPE=mongodb
# DATABASE_TYPE=both

# ============================================================================
# POSTGRESQL CONFIGURATION
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=baseline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_SSL=false

# Connection pool settings
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ============================================================================
# MONGODB CONFIGURATION
# ============================================================================
MONGO_URI=mongodb://localhost:27017/baseline
# OR for MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/personaltrainer

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
# NODE_ENV=production
PORT=3000
API_URL=http://localhost:3000

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here_use_strong_random_string
JWT_EXPIRY=7d

# ============================================================================
# CORS & SECURITY
# ============================================================================
FRONTEND_URL=http://localhost:5173
# For production:
# FRONTEND_URL=https://yourfrontend.com

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
# LOG_LEVEL=info
